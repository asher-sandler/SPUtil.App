<UserControl x:Class="SPUtil.App.Views.PagesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" d:DesignHeight="600" d:DesignWidth="900">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- Subtle separator style -->
        <Style x:Key="PropKey" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
        </Style>
        <Style x:Key="PropVal" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 0: page toolbar -->
            <RowDefinition Height="Auto"/>  <!-- 1: status -->
            <RowDefinition Height="*"/>     <!-- 2: pages grid -->
            <RowDefinition Height="5"/>     <!-- 3: splitter -->
            <RowDefinition Height="Auto"/>  <!-- 4: WP toolbar -->
            <RowDefinition Height="*"/>     <!-- 5: WP list + properties panel -->
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════
             Row 0 — Page toolbar (source mode only)
        ══════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="#F5F5F5" BorderBrush="#CCCCCC" BorderThickness="0,0,0,1"
                Visibility="{Binding IsSourceMode, Converter={StaticResource BoolToVis}}"
                Padding="5" Margin="0,0,0,6">
            <StackPanel Orientation="Horizontal">

                <Button Command="{Binding GetAllPropertiesCommand}"
                        Background="Transparent" BorderBrush="Transparent" Cursor="Hand"
                        ToolTip="Dump all WebPart properties to Output window">
                    <TextBlock Text="&#xE8FD;" Style="{StaticResource IconText}" Foreground="#107C10"/>
                </Button>

                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="5,0"/>

                <Button Command="{Binding ShowWebPartsPreviewCommand}"
                        Background="Transparent" BorderBrush="Transparent" Cursor="Hand"
                        ToolTip="View all WebPart properties">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE7C3;" Style="{StaticResource IconText}" Foreground="#2B579A"/>
                        <TextBlock Text="View WP" VerticalAlignment="Center" FontSize="12"
                                   Foreground="#2B579A" Margin="3,0,0,0"/>
                    </StackPanel>
                </Button>

                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="5,0"/>

                <Button Command="{Binding CopyPageCommand}"
                        Background="Transparent" BorderBrush="Transparent" Cursor="Hand"
                        ToolTip="Copy this page to target site">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8C8;" Style="{StaticResource IconText}" Foreground="#0066CC"/>
                        <TextBlock Text=" Copy Page" VerticalAlignment="Center" FontSize="12"
                                   Foreground="#0066CC" Margin="3,0,0,0"/>
                    </StackPanel>
                </Button>

                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="5,0"/>

                <Button Command="{Binding RenamePageCommand}"
                        Background="Transparent" BorderBrush="Transparent" Cursor="Hand"
                        ToolTip="Rename selected page">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8AC;" Style="{StaticResource IconText}" Foreground="#6B2D8B"/>
                        <TextBlock Text=" Rename" VerticalAlignment="Center" FontSize="12"
                                   Foreground="#6B2D8B" Margin="3,0,0,0"/>
                    </StackPanel>
                </Button>

                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="5,0"/>

                <Button Command="{Binding DeletePageCommand}"
                        Background="Transparent" BorderBrush="Transparent" Cursor="Hand"
                        ToolTip="Delete selected page permanently">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE74D;" Style="{StaticResource IconText}" Foreground="#A80000"/>
                        <TextBlock Text=" Delete" VerticalAlignment="Center" FontSize="12"
                                   Foreground="#A80000" Margin="3,0,0,0"/>
                    </StackPanel>
                </Button>

                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="5,0"/>

                <Button Command="{Binding ComparePageCommand}"
                        Background="Transparent" BorderBrush="Transparent" Cursor="Hand"
                        ToolTip="Compare all WebParts with the same page on target site">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE912;" Style="{StaticResource IconText}" Foreground="#856404"/>
                        <TextBlock Text=" Compare" VerticalAlignment="Center" FontSize="12"
                                   Foreground="#856404" Margin="3,0,0,0"/>
                    </StackPanel>
                </Button>

                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="5,0"/>

                <Button Command="{Binding SyncPropertiesCommand}"
                        Background="Transparent" BorderBrush="Transparent" Cursor="Hand"
                        ToolTip="Sync ALL WebPart properties from source (requires placeholders on page)">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE72C;" Style="{StaticResource IconText}" Foreground="#107C10"/>
                        <TextBlock Text=" Sync All" VerticalAlignment="Center" FontSize="12"
                                   Foreground="#107C10" Margin="3,0,0,0"/>
                    </StackPanel>
                </Button>

            </StackPanel>
        </Border>

        <!-- Row 1 — Status -->
        <TextBlock Grid.Row="1"
                   Text="{Binding StatusMessage}"
                   Foreground="DarkBlue" Margin="0,0,0,5" FontWeight="Bold"/>

        <!-- Row 2 — Pages list -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Pages}"
                  SelectedItem="{Binding SelectedPage}"
                  AutoGenerateColumns="False" CanUserAddRows="False"
                  IsReadOnly="True" Background="White"
                  HorizontalScrollBarVisibility="Visible"
                  ColumnWidth="Auto">
            <DataGrid.Columns>
                <DataGridTextColumn Binding="{Binding Name}" Width="250" MinWidth="150">
                    <DataGridTextColumn.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Name"/>
                            <!-- TextBlock Text=" ▲" Foreground="#0066CC" FontSize="10"
                                       VerticalAlignment="Center" Margin="3,0,0,0"
                                       ToolTip="Sorted A→Z by name"/ -->
                        </StackPanel>
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Path" Binding="{Binding FullPath}" Width="600" MinWidth="200"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Row 3 — Splitter -->
        <GridSplitter Grid.Row="3" Height="5" HorizontalAlignment="Stretch"
                      Background="#EEE" Cursor="SizeNS"/>

        <!-- ══════════════════════════════════════════
             Row 4 — WebPart toolbar (source mode only)
        ══════════════════════════════════════════════ -->
        <Border Grid.Row="4"
                Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="0,1,0,1"
                Visibility="{Binding IsSourceMode, Converter={StaticResource BoolToVis}}"
                Padding="4,3">
            <StackPanel Orientation="Horizontal">

                <TextBlock Text="Selected WP:" VerticalAlignment="Center"
                           FontSize="11" Foreground="#888" Margin="4,0,8,0"/>

                <Button Command="{Binding CompareWebPartCommand}"
                        Background="Transparent" BorderBrush="Transparent" Cursor="Hand"
                        ToolTip="Compare selected WebPart with matching WP on target page">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE912;" Style="{StaticResource IconText}"
                                   Foreground="#856404" FontSize="14"/>
                        <TextBlock Text=" Compare WP" VerticalAlignment="Center" FontSize="12"
                                   Foreground="#856404" Margin="3,0,0,0"/>
                    </StackPanel>
                </Button>

                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="5,0"/>

                <Button Command="{Binding CopyWebPartPropertiesCommand}"
                        Background="Transparent" BorderBrush="Transparent" Cursor="Hand"
                        ToolTip="Copy selected WebPart properties to matching WP on target page">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8C8;" Style="{StaticResource IconText}"
                                   Foreground="#0066CC" FontSize="14"/>
                        <TextBlock Text=" Copy WP Properties" VerticalAlignment="Center" FontSize="12"
                                   Foreground="#0066CC" Margin="3,0,0,0"/>
                    </StackPanel>
                </Button>

            </StackPanel>
        </Border>

        <!-- ══════════════════════════════════════════════════════
             Row 5 — WebParts list (left) + Properties panel (right)
        ══════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>     <!-- WP list -->
                <ColumnDefinition Width="5"/>       <!-- splitter -->
                <ColumnDefinition Width="*"/>       <!-- properties panel -->
            </Grid.ColumnDefinitions>

            <!-- Left: WebPart list — only # and Title -->
            <GroupBox Grid.Column="0" Header="Web Parts">
                <DataGrid ItemsSource="{Binding WebParts}"
                          SelectedItem="{Binding SelectedWebPart}"
                          AutoGenerateColumns="False" CanUserAddRows="False"
                          IsReadOnly="True" Background="White"
                          SelectionMode="Single"
                          BorderThickness="0">
                    <DataGrid.Columns>

                        <DataGridTextColumn Header="#" Binding="{Binding VisualPosition}" Width="35">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="#888"/>
                                    <Setter Property="FontSize" Value="11"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="*"/>

                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <!-- Vertical splitter -->
            <GridSplitter Grid.Column="1" Width="5"
                          VerticalAlignment="Stretch" HorizontalAlignment="Center"
                          Background="#EEE" Cursor="SizeWE"/>

            <!-- Right: Properties of selected WebPart -->
            <GroupBox Grid.Column="2" Header="Properties">

                <!-- Placeholder when nothing selected -->
                <Grid >
                    <TextBlock Text="Select a WebPart to view its properties."
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="#AAA" FontStyle="Italic" FontSize="12">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedWebPart}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Properties panel — visible when a WP is selected -->
                    <Grid>
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedWebPart}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>  <!-- WP header info -->
                            <RowDefinition Height="*"/>     <!-- property list -->
                        </Grid.RowDefinitions>

                        <!-- WP header: Title / Zone / StorageKey + Copy button -->
                        <Border Grid.Row="0"
                                Background="#F0F4FF" BorderBrush="#C8D8FF"
                                BorderThickness="0,0,0,1" Padding="8,6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Title: " Style="{StaticResource PropKey}"/>
                                        <TextBlock Text="{Binding SelectedWebPart.Title}"
                                                   FontSize="12" FontWeight="Bold" Foreground="#1a1a7a"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                        <TextBlock Text="Zone: " Style="{StaticResource PropKey}"/>
                                        <TextBlock Text="{Binding SelectedWebPart.ZoneId}"
                                                   Style="{StaticResource PropVal}"/>
                                        <TextBlock Text="   StorageKey: " Style="{StaticResource PropKey}"
                                                   Margin="12,0,4,0"/>
                                        <TextBlock Text="{Binding SelectedWebPart.StorageKey}"
                                                   Style="{StaticResource PropVal}" FontFamily="Consolas"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Copy to clipboard button -->
                                <Button Grid.Column="1"
                                        Command="{Binding CopyWpToClipboardCommand}"
                                        Background="Transparent" BorderBrush="Transparent"
                                        Cursor="Hand" VerticalAlignment="Center"
                                        Padding="6,4"
                                        ToolTip="Copy all properties to clipboard (with page name)">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE8C8;"
                                                   Style="{StaticResource IconText}"
                                                   Foreground="#0066CC" FontSize="14"/>
                                        <TextBlock Text=" Copy" VerticalAlignment="Center"
                                                   FontSize="11" Foreground="#0066CC" Margin="3,0,0,0"/>
                                    </StackPanel>
                                </Button>

                            </Grid>
                        </Border>

                        <!-- Property list -->
                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Visible">
                            <ItemsControl ItemsSource="{Binding SelectedWebPart.Properties}"
                                          Margin="4,4,4,4">
                                <ItemsControl.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="📋  Copy all properties to clipboard"
                                                  Command="{Binding PlacementTarget.DataContext.CopyWpToClipboardCommand,
                                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    </ContextMenu>
                                </ItemsControl.ContextMenu>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="180"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Key}"
                                                       Style="{StaticResource PropKey}"
                                                       VerticalAlignment="Top"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Value}"
                                                       Style="{StaticResource PropVal}"
                                                       VerticalAlignment="Top"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                    </Grid>
                </Grid>
            </GroupBox>

        </Grid>

    </Grid>
</UserControl>
