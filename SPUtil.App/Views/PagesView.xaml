<UserControl x:Class="SPUtil.App.Views.PagesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" d:DesignHeight="600" d:DesignWidth="800">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*"    />
            <RowDefinition Height="5"    />
            <RowDefinition Height="*"    />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#F5F5F5" BorderBrush="#CCCCCC" BorderThickness="0,0,0,1"
                Visibility="{Binding IsSourceMode, Converter={StaticResource BooleanToVisibilityConverter}}"
                Padding="5" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">

                <Button Command="{Binding GetAllPropertiesCommand}"
                        Background="Transparent" BorderBrush="Transparent" Cursor="Hand"
                        ToolTip="Вывести все Properties в лог (Output)">
                    <TextBlock Text="&#xE8FD;" Style="{StaticResource IconText}" Foreground="#107C10"/>
                </Button>

                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="5,0"/>

                <Button Command="{Binding ShowWebPartsPreviewCommand}"
                        Background="Transparent" BorderBrush="Transparent" Cursor="Hand"
                        ToolTip="Открыть все свойства WebParts в окне предпросмотра">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE7C3;" Style="{StaticResource IconText}" Foreground="#2B579A"/>
                        <TextBlock Text=" Preview" VerticalAlignment="Center" FontSize="12" Foreground="#2B579A" Margin="3,0,0,0"/>
                    </StackPanel>
                </Button>

                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="5,0"/>

                <!-- Copy Page to target site -->
                <Button Command="{Binding CopyPageCommand}"
                        Background="Transparent" BorderBrush="Transparent" Cursor="Hand"
                        ToolTip="Copy selected page to target site (right pane)">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8C8;" Style="{StaticResource IconText}" Foreground="#0066CC"/>
                        <TextBlock Text=" Copy Page" VerticalAlignment="Center" FontSize="12" Foreground="#0066CC" Margin="3,0,0,0"/>
                    </StackPanel>
                </Button>

                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="5,0"/>

                <!-- Rename Page -->
                <Button Command="{Binding RenamePageCommand}"
                        Background="Transparent" BorderBrush="Transparent" Cursor="Hand"
                        ToolTip="Rename selected page (changes filename, not Title)">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8AC;" Style="{StaticResource IconText}" Foreground="#6B2D8B"/>
                        <TextBlock Text=" Rename" VerticalAlignment="Center" FontSize="12" Foreground="#6B2D8B" Margin="3,0,0,0"/>
                    </StackPanel>
                </Button>

                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="5,0"/>

                <!-- Delete Page -->
                <Button Command="{Binding DeletePageCommand}"
                        Background="Transparent" BorderBrush="Transparent" Cursor="Hand"
                        ToolTip="Delete selected page permanently">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE74D;" Style="{StaticResource IconText}" Foreground="#A80000"/>
                        <TextBlock Text=" Delete" VerticalAlignment="Center" FontSize="12" Foreground="#A80000" Margin="3,0,0,0"/>
                    </StackPanel>
                </Button>

            </StackPanel>
        </Border>

        <TextBlock Grid.Row="1" Text="{Binding StatusMessage}"
                   Foreground="DarkBlue" Margin="0,0,0,5" FontWeight="Bold"/>

        <DataGrid Grid.Row="2" ItemsSource="{Binding Pages}" SelectedItem="{Binding SelectedPage}"
                  AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" Background="White">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Имя"  Binding="{Binding Name}"       Width="250" />
                <DataGridTextColumn Header="Путь" Binding="{Binding RelativeUrl}" Width="*"   />
            </DataGrid.Columns>
        </DataGrid>

        <GridSplitter Grid.Row="3" Height="5" HorizontalAlignment="Stretch" Background="#EEE" Cursor="SizeNS"/>

        <GroupBox Grid.Row="4" Header="Веб-части выбранной страницы">
            <DataGrid ItemsSource="{Binding WebParts}" AutoGenerateColumns="False"
                      CanUserAddRows="False" IsReadOnly="True" Background="White">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Заголовок"  Binding="{Binding Title}"      Width="200" />
                    <DataGridTextColumn Header="Тип"        Binding="{Binding Type}"       Width="150" />
                    <DataGridTextColumn Header="StorageKey" Binding="{Binding StorageKey}" Width="270" />
                    <DataGridTemplateColumn Header="Свойства" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ScrollViewer MaxHeight="150" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding Properties}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="2">
                                                    <TextBlock Text="{Binding Key}" FontWeight="Bold" Foreground="#333"/>
                                                    <TextBlock Text=": "/>
                                                    <TextBlock Text="{Binding Value}" TextWrapping="Wrap" Foreground="#666"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>
    </Grid>
</UserControl>
