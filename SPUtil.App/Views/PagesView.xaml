<UserControl x:Class="SPUtil.App.Views.PagesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:scm="clr-namespace:System.ComponentModel;assembly=WindowsBase"
             mc:Ignorable="d" d:DesignHeight="600" d:DesignWidth="900">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- Sort Pages by Name ascending -->
        <CollectionViewSource x:Key="SortedPages" Source="{Binding Pages}">
            <CollectionViewSource.SortDescriptions>
                <scm:SortDescription PropertyName="Name" Direction="Ascending"/>
            </CollectionViewSource.SortDescriptions>
        </CollectionViewSource>

        <!-- Subtle property styles -->
        <Style x:Key="PropKey" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
        </Style>
        <Style x:Key="PropVal" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <!-- Menu icon helpers -->
        <TextBlock x:Key="IconMenuPreview" Text="&#xE7C3;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="#2B579A"/>
        <TextBlock x:Key="IconMenuCopy"    Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="#0066CC"/>
        <TextBlock x:Key="IconMenuRename"  Text="&#xE8AC;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="#6B2D8B"/>
        <TextBlock x:Key="IconMenuDelete"  Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="#A80000"/>
        <TextBlock x:Key="IconMenuCompare" Text="&#xE912;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="#856404"/>
        <TextBlock x:Key="IconMenuSync"    Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="#107C10"/>
        <TextBlock x:Key="IconMenuExport"  Text="&#xE943;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="#8B4513"/>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 0: page toolbar -->
            <RowDefinition Height="Auto"/>  <!-- 1: status -->
            <RowDefinition Height="*"/>     <!-- 2: pages grid -->
            <RowDefinition Height="5"/>     <!-- 3: splitter -->
            <RowDefinition Height="Auto"/>  <!-- 4: WP toolbar -->
            <RowDefinition Height="*"/>     <!-- 5: WP list + properties panel -->
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════
             Row 0 — Page toolbar (source mode only)
             Layout: [☰ menu] | [icon-only frequent actions] | stretch | [status label]
        ══════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="#F5F5F5" BorderBrush="#CCCCCC" BorderThickness="0,0,0,1"
                Visibility="{Binding IsSourceMode, Converter={StaticResource BoolToVis}}"
                Padding="4,3" Margin="0,0,0,6">
            <DockPanel LastChildFill="False">

                <!-- ── Hamburger menu button ─────────────────────────── -->
                <Button x:Name="BtnHamburger"
                        DockPanel.Dock="Left"
                        Background="Transparent" BorderBrush="Transparent"
                        Cursor="Hand" Padding="6,4"
                        Click="BtnHamburger_Click"
                        ToolTip="All page actions">
                    <Button.Content>
                        <TextBlock Text="&#xE700;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="16" Foreground="#333"
                                   VerticalAlignment="Center"/>
                    </Button.Content>
                    <Button.ContextMenu>
                        <ContextMenu>
                            <!-- Page operations -->
                            <MenuItem Header="View WebParts (Preview)"
                                      Command="{Binding ShowWebPartsPreviewCommand}"
                                      Icon="{StaticResource IconMenuPreview}"/>
                            <MenuItem Header="Copy Page to target site"
                                      Command="{Binding CopyPageCommand}"
                                      Icon="{StaticResource IconMenuCopy}"/>
                            <MenuItem Header="Rename Page"
                                      Command="{Binding RenamePageCommand}"
                                      Icon="{StaticResource IconMenuRename}"/>
                            <Separator/>
                            <!-- WebPart sync -->
                            <MenuItem Header="Compare Page WebParts with target"
                                      Command="{Binding ComparePageCommand}"
                                      Icon="{StaticResource IconMenuCompare}"/>
                            <MenuItem Header="Sync All WebPart Properties"
                                      Command="{Binding SyncPropertiesCommand}"
                                      Icon="{StaticResource IconMenuSync}"/>
                            <Separator/>
                            <!-- Export -->
                            <MenuItem Header="Export WebParts as PowerShell script"
                                      Command="{Binding ExportWpToPowerShellCommand}"
                                      Icon="{StaticResource IconMenuExport}"/>
                            <Separator/>
                            <!-- Debug -->
                            <MenuItem Header="Dump all properties to Output"
                                      Command="{Binding GetAllPropertiesCommand}"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                    <!-- Open ContextMenu on left-click too -->

                </Button>

                <Rectangle DockPanel.Dock="Left" Width="1" Fill="#CCC" Margin="4,4,4,4"/>

                <!-- ── Frequent actions — icon only ──────────────────── -->
                <Button DockPanel.Dock="Left"
                        Command="{Binding ShowWebPartsPreviewCommand}"
                        Background="Transparent" BorderBrush="Transparent"
                        Cursor="Hand" Padding="5,4"
                        ToolTip="View WebParts (Preview)">
                    <TextBlock Text="&#xE7C3;" FontFamily="Segoe MDL2 Assets"
                               FontSize="15" Foreground="#2B579A"/>
                </Button>

                <Button DockPanel.Dock="Left"
                        Command="{Binding CopyPageCommand}"
                        Background="Transparent" BorderBrush="Transparent"
                        Cursor="Hand" Padding="5,4"
                        ToolTip="Copy Page to target site">
                    <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets"
                               FontSize="15" Foreground="#0066CC"/>
                </Button>

                <Button DockPanel.Dock="Left"
                        Command="{Binding RenamePageCommand}"
                        Background="Transparent" BorderBrush="Transparent"
                        Cursor="Hand" Padding="5,4"
                        ToolTip="Rename Page">
                    <TextBlock Text="&#xE8AC;" FontFamily="Segoe MDL2 Assets"
                               FontSize="15" Foreground="#6B2D8B"/>
                </Button>

                <Rectangle DockPanel.Dock="Left" Width="1" Fill="#CCC" Margin="4,4,4,4"/>

                <Button DockPanel.Dock="Left"
                        Command="{Binding ComparePageCommand}"
                        Background="Transparent" BorderBrush="Transparent"
                        Cursor="Hand" Padding="5,4"
                        ToolTip="Compare Page WebParts with target">
                    <TextBlock Text="&#xE912;" FontFamily="Segoe MDL2 Assets"
                               FontSize="15" Foreground="#856404"/>
                </Button>

                <Button DockPanel.Dock="Left"
                        Command="{Binding SyncPropertiesCommand}"
                        Background="Transparent" BorderBrush="Transparent"
                        Cursor="Hand" Padding="5,4"
                        ToolTip="Sync All WebPart Properties">
                    <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets"
                               FontSize="15" Foreground="#107C10"/>
                </Button>

                <Button DockPanel.Dock="Left"
                        Command="{Binding ExportWpToPowerShellCommand}"
                        Background="Transparent" BorderBrush="Transparent"
                        Cursor="Hand" Padding="5,4"
                        ToolTip="Export WebParts as PowerShell script">
                    <TextBlock Text="&#xE943;" FontFamily="Segoe MDL2 Assets"
                               FontSize="15" Foreground="#8B4513"/>
                </Button>

            </DockPanel>
        </Border>

        <!-- Row 1 — Status -->
        <TextBlock Grid.Row="1"
                   Text="{Binding StatusMessage}"
                   Foreground="DarkBlue" Margin="0,0,0,5" FontWeight="Bold"/>

        <!-- Row 2 — Pages list -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Source={StaticResource SortedPages}}"
                  SelectedItem="{Binding SelectedPage}"
                  AutoGenerateColumns="False" CanUserAddRows="False"
                  IsReadOnly="True" Background="White"
                  HorizontalScrollBarVisibility="Visible"
                  ColumnWidth="Auto">
            <DataGrid.Columns>
                <DataGridTextColumn Binding="{Binding Name}" Width="250" MinWidth="150">
                    <DataGridTextColumn.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Name"/>
                            <!-- TextBlock Text=" ▲" Foreground="#0066CC" FontSize="10"
                                       VerticalAlignment="Center" Margin="3,0,0,0"
                                       ToolTip="Sorted A→Z by name"/ -->
                        </StackPanel>
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Path" Binding="{Binding FullPath}" Width="600" MinWidth="200"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Row 3 — Splitter -->
        <GridSplitter Grid.Row="3" Height="5" HorizontalAlignment="Stretch"
                      Background="#EEE" Cursor="SizeNS"/>

        <!-- ══════════════════════════════════════════
             Row 4 — WebPart toolbar (source mode only)
        ══════════════════════════════════════════════ -->
        <Border Grid.Row="4"
                Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="0,1,0,1"
                Visibility="{Binding IsSourceMode, Converter={StaticResource BoolToVis}}"
                Padding="4,3">
            <DockPanel LastChildFill="False">

                <!-- Hamburger menu for WP actions -->
                <Button x:Name="BtnWpHamburger"
                        DockPanel.Dock="Left"
                        Background="Transparent" BorderBrush="Transparent"
                        Cursor="Hand" Padding="6,4"
                        Click="BtnWpHamburger_Click"
                        ToolTip="All WebPart actions">
                    <TextBlock Text="&#xE700;" FontFamily="Segoe MDL2 Assets"
                               FontSize="16" Foreground="#333"/>
                    <Button.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Compare WP with target page"
                                      Command="{Binding CompareWebPartCommand}"
                                      Icon="{StaticResource IconMenuCompare}"/>
                            <MenuItem Header="Copy WP Properties to target"
                                      Command="{Binding CopyWebPartPropertiesCommand}"
                                      Icon="{StaticResource IconMenuCopy}"/>
                            <Separator/>
                            <MenuItem Header="Copy WP properties to clipboard"
                                      Command="{Binding CopyWpToClipboardCommand}"
                                      Icon="{StaticResource IconMenuPreview}"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>

                <Rectangle DockPanel.Dock="Left" Width="1" Fill="#CCC" Margin="4,4,4,4"/>

                <!-- Icon-only quick actions -->
                <Button DockPanel.Dock="Left"
                        Command="{Binding CompareWebPartCommand}"
                        Background="Transparent" BorderBrush="Transparent"
                        Cursor="Hand" Padding="5,4"
                        ToolTip="Compare selected WebPart with target page">
                    <TextBlock Text="&#xE912;" FontFamily="Segoe MDL2 Assets"
                               FontSize="15" Foreground="#856404"/>
                </Button>

                <Button DockPanel.Dock="Left"
                        Command="{Binding CopyWebPartPropertiesCommand}"
                        Background="Transparent" BorderBrush="Transparent"
                        Cursor="Hand" Padding="5,4"
                        ToolTip="Copy WP Properties to target page">
                    <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets"
                               FontSize="15" Foreground="#0066CC"/>
                </Button>

                <Button DockPanel.Dock="Left"
                        Command="{Binding CopyWpToClipboardCommand}"
                        Background="Transparent" BorderBrush="Transparent"
                        Cursor="Hand" Padding="5,4"
                        ToolTip="Copy WP properties to clipboard">
                    <TextBlock Text="&#xE8D0;" FontFamily="Segoe MDL2 Assets"
                               FontSize="15" Foreground="#555"/>
                </Button>

            </DockPanel>
        </Border>

        <!-- ══════════════════════════════════════════════════════
             Row 5 — WebParts list (left) + Properties panel (right)
        ══════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>     <!-- WP list -->
                <ColumnDefinition Width="5"/>       <!-- splitter -->
                <ColumnDefinition Width="*"/>       <!-- properties panel -->
            </Grid.ColumnDefinitions>

            <!-- Left: WebPart list — only # and Title -->
            <GroupBox Grid.Column="0" Header="Web Parts">
                <DataGrid ItemsSource="{Binding WebParts}"
                          SelectedItem="{Binding SelectedWebPart}"
                          AutoGenerateColumns="False" CanUserAddRows="False"
                          IsReadOnly="True" Background="White"
                          SelectionMode="Single"
                          BorderThickness="0">
                    <DataGrid.Columns>

                        <DataGridTextColumn Header="#" Binding="{Binding VisualPosition}" Width="35">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="#888"/>
                                    <Setter Property="FontSize" Value="11"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="*"/>

                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <!-- Vertical splitter -->
            <GridSplitter Grid.Column="1" Width="5"
                          VerticalAlignment="Stretch" HorizontalAlignment="Center"
                          Background="#EEE" Cursor="SizeWE"/>

            <!-- Right: Properties of selected WebPart -->
            <GroupBox Grid.Column="2" Header="Properties">

                <!-- Placeholder when nothing selected -->
                <Grid >
                    <TextBlock Text="Select a WebPart to view its properties."
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="#AAA" FontStyle="Italic" FontSize="12">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedWebPart}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Properties panel — visible when a WP is selected -->
                    <Grid>
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedWebPart}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>  <!-- WP header info -->
                            <RowDefinition Height="*"/>     <!-- property list -->
                        </Grid.RowDefinitions>

                        <!-- WP header: Title / Zone / StorageKey -->
                        <Border Grid.Row="0"
                                Background="#F0F4FF" BorderBrush="#C8D8FF"
                                BorderThickness="0,0,0,1" Padding="8,6">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Title: " Style="{StaticResource PropKey}"/>
                                    <TextBlock Text="{Binding SelectedWebPart.Title}"
                                               FontSize="12" FontWeight="Bold" Foreground="#1a1a7a"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Text="Zone: " Style="{StaticResource PropKey}"/>
                                    <TextBlock Text="{Binding SelectedWebPart.ZoneId}"
                                               Style="{StaticResource PropVal}"/>
                                    <TextBlock Text="   StorageKey: " Style="{StaticResource PropKey}"
                                               Margin="12,0,4,0"/>
                                    <TextBlock Text="{Binding SelectedWebPart.StorageKey}"
                                               Style="{StaticResource PropVal}" FontFamily="Consolas"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Property list -->
                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Visible">
                            <ItemsControl ItemsSource="{Binding SelectedWebPart.Properties}"
                                          Margin="4,4,4,4">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="180"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Key}"
                                                       Style="{StaticResource PropKey}"
                                                       VerticalAlignment="Top"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Value}"
                                                       Style="{StaticResource PropVal}"
                                                       VerticalAlignment="Top"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                    </Grid>
                </Grid>
            </GroupBox>

        </Grid>

    </Grid>
</UserControl>
