<Window x:Class="SPUtil.App.Views.SchemaViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Schema viewer"
        Height="700"
        Width="1000"
        WindowStartupLocation="CenterOwner"
        Background="#2D2D2D">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBox x:Name="XmlBox"
                 IsReadOnly="True"
                 AcceptsReturn="True"
                 FontFamily="Consolas"
                 FontSize="14"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 TextWrapping="NoWrap"
                 Background="#1E1E1E"
                 Foreground="#D4D4D4"
                 CaretBrush="#D4D4D4"
                 Padding="10"
                 BorderThickness="1"
                 BorderBrush="#3E3E42">
            <TextBox.Resources>
                <Style TargetType="{x:Type ScrollBar}">
                    <Setter Property="Background"
                            Value="#1E1E1E" />
                </Style>
            </TextBox.Resources>
        </TextBox>
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,15,0,0">
            <Button Content="Copy to clipboard"
                    Width="160"
                    Height="35"
                    Margin="5,0"
                    Click="Copy_Click"
                    Background="#3E3E42"
                    Foreground="White"
                    BorderThickness="0" />
            <Button Content="Save as XML"
                    Width="160"
                    Height="35"
                    Margin="5,0"
                    Click="Save_Click"
                    Background="#3E3E42"
                    Foreground="White"
                    BorderThickness="0" />
            <Button Content="Close"
                    Width="100"
                    Height="35"
                    Margin="5,0"
                    IsCancel="True"
                    Background="#3E3E42"
                    Foreground="White"
                    BorderThickness="0" />
        </StackPanel>
    </Grid>
</Window>