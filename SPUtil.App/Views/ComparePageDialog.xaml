<Window x:Class="SPUtil.Views.ComparePageDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Compare Page"
        Height="280" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="#F0F0F0">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="Padding" Value="10,2"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="15,12,15,15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- source info -->
            <RowDefinition Height="Auto"/>  <!-- target site -->
            <RowDefinition Height="Auto"/>  <!-- target page name -->
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>  <!-- footer -->
        </Grid.RowDefinitions>

        <!-- Source info -->
        <GroupBox Grid.Row="0" Header="Source Page" Margin="0,0,0,12" Background="White">
            <TextBox x:Name="TxtInfo"
                     Margin="8,6"
                     TextWrapping="Wrap"
                     Foreground="#555"
                     IsReadOnly="True"
                     BorderThickness="0"
                     Background="Transparent"
                     MaxHeight="60"/>
        </GroupBox>

        <!-- Target site (read-only) -->
        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="Target Site URL:" Foreground="#444" Margin="0,0,0,3"/>
            <TextBox x:Name="TxtTargetUrl"
                     IsReadOnly="True"
                     Background="#E9E9E9"
                     BorderBrush="#CCC"
                     Height="26"
                     VerticalContentAlignment="Center"
                     Padding="5,0"/>
        </StackPanel>

        <!-- Target page name -->
        <StackPanel Grid.Row="2" Margin="0,0,0,8">
            <TextBlock Text="Target Page Name (without .aspx):"
                       FontWeight="SemiBold" Foreground="Black" Margin="0,0,0,3"/>
            <TextBox x:Name="TxtTargetPageName"
                     Height="28"
                     VerticalContentAlignment="Center"
                     BorderBrush="#0078D7"
                     Padding="5,0"/>
        </StackPanel>

        <!-- Footer -->
        <Border Grid.Row="4"
                Padding="0,10,0,0"
                BorderBrush="#DDD"
                BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Compare"
                        Width="100"
                        Margin="5,0"
                        Click="BtnCompare_Click"
                        IsDefault="True"
                        Background="#E1F5FE"
                        BorderBrush="#039BE5"
                        FontWeight="SemiBold"/>
                <Button Content="Cancel"
                        Width="100"
                        Margin="5,0"
                        IsCancel="True"
                        Background="White"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
