<UserControl x:Class="SPUtil.App.Views.List100View"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"> 
             
	<UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

    </UserControl.Resources>
	
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
 <Grid Margin="10">
    <Grid.RowDefinitions>
        <RowDefinition Height="Auto" /> 
		<RowDefinition Height="Auto" /> 
		<RowDefinition Height="*" />    
	</Grid.RowDefinitions>

  <!-- Background="#FFF4CE"	-->
<Border Grid.Row="0" 
	Background="#F5F5F5" 
	BorderBrush="#CCCCCC" 
	BorderThickness="0,0,0,1" 
	Visibility="{Binding IsSourceMode, Converter={StaticResource BooleanToVisibilityConverter}}"
	Padding="5">
    <StackPanel Grid.Row="0" 
				Orientation="Horizontal" 
				Margin="0,0,0,10"
			
				Visibility="{Binding IsSourceMode, Converter={StaticResource BooleanToVisibilityConverter}}">
        
        <Button Style="{StaticResource IconButton}" 
                Command="{Binding CreateOnTargetCommand}"
                 ToolTip="Создать этот список на целевом сайте">
            <TextBlock Text="&#xE710;" Style="{StaticResource IconText}" Foreground="#0078D4"/>
        </Button>
        <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="5,0"/>

        <Button Style="{StaticResource IconButton}" 
                Command="{Binding CopyWithDataCommand}"
                ToolTip="Копировать структуру вместе с данными">
            <TextBlock Text="&#xE8C8;" Style="{StaticResource IconText}" Foreground="#2B579A"/>
        </Button>
        <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="5,0"/>

        <Button Style="{StaticResource IconButton}" 
                Command="{Binding CopyViewsCommand}"
                ToolTip="Скопировать только представления (Views)">
            <TextBlock Text="&#xE7B3;" Style="{StaticResource IconText}" Foreground="#107C10"/>
        </Button>

        <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="5,0"/>

        <Button Style="{StaticResource IconButton}" 
                Command="{Binding CompareCommand}"
                ToolTip="Проверить соответствие структур (Compare)"
                >
            <TextBlock Text="&#xE912;" Style="{StaticResource IconText}" Foreground="#856404"/>
        </Button>
    </StackPanel>
	</Border>

    <StackPanel Grid.Row="1" Margin="0,0,0,10">
        <TextBlock Text="{Binding ListTitle}" 
				FontSize="18" FontWeight="Bold" Foreground="#333333">
            <TextBlock.Effect>
                <DropShadowEffect BlurRadius="3" Direction="315" ShadowDepth="1.5" Opacity="0.4" Color="Gray"/>
            </TextBlock.Effect>
        </TextBlock>
		<TextBlock Text="Custom List (Type 100)"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="#0078D4" />
    </StackPanel>

    <!--TabControl Grid.Row="2">
        </TabControl-->
</Grid>
        <TabControl Grid.Row="1">
			<TabItem Header="Items">
				<Grid>
					<DataGrid ItemsSource="{Binding Items}" 
							  AutoGenerateColumns="False" 
							  CanUserAddRows="False"
							  IsReadOnly="False" 
							  Background="White">
						<DataGrid.Columns>
							<DataGridCheckBoxColumn Header="Sel" Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="40"/>
							
							<DataGridTextColumn Header="ID" Binding="{Binding Id}" IsReadOnly="True" Width="50"/>
							<DataGridTextColumn Header="Title" Binding="{Binding Title}" IsReadOnly="True" Width="*"/>
						</DataGrid.Columns>
					</DataGrid>
				</Grid>
			</TabItem>
            <TabItem Header="Fields">
				<DataGrid ItemsSource="{Binding Fields}" AutoGenerateColumns="False">
					<DataGrid.Columns>
						<DataGridTextColumn Header="Название" Binding="{Binding Title}"/>
						<DataGridTextColumn Header="Внутреннее имя" Binding="{Binding InternalName}"/>
						<DataGridTextColumn Header="Тип" Binding="{Binding TypeAsString}"/>
					</DataGrid.Columns>
				</DataGrid>
			</TabItem>
			<TabItem Header="Views">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="*" />    <RowDefinition Height="5" />    <RowDefinition Height="180" />  </Grid.RowDefinitions>

					<DataGrid Grid.Row="0" 
							  ItemsSource="{Binding Views}" 
							  SelectedItem="{Binding SelectedView, UpdateSourceTrigger=PropertyChanged}" 
							  AutoGenerateColumns="False" 
							  CanUserAddRows="False" 
							  IsReadOnly="True" 
							  Background="White">
						<DataGrid.Columns>
							<DataGridTextColumn Header="Название" Binding="{Binding Title}" Width="200" />
							<DataGridCheckBoxColumn Header="Default" Binding="{Binding DefaultView}" Width="60" />
							<DataGridTextColumn Header="URL" Binding="{Binding ServerRelativeUrl}" Width="*" />
						</DataGrid.Columns>
					</DataGrid>

					<GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch" Background="#EEE" Cursor="SizeNS"/>

					<GroupBox Grid.Row="2" Header="CAML Query (XML)">
						<TextBox Text="{Binding SelectedView.ViewQuery, Mode=OneWay}" 
								 IsReadOnly="True" 
								 TextWrapping="Wrap" 
								 AcceptsReturn="True" 
								 VerticalScrollBarVisibility="Auto"
								 FontFamily="Consolas" 
								 FontSize="12"
								 Background="#F9F9F9"
								 BorderThickness="0"
								 Margin="2"/>
					</GroupBox>
				</Grid>
			</TabItem>
        </TabControl>
        <!--UniformGrid Grid.Row="2"
                     Columns="2"
                     Margin="0,10,0,0">
            <Button Content="Создать на целевом"
                    Command="{Binding CreateOnTargetCommand}"
					Visibility="{Binding IsSourceMode, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Margin="5"
                    Height="30" />
            <Button Content="Копировать данные"
                    Command="{Binding CopyWithDataCommand}"
					Visibility="{Binding IsSourceMode, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Margin="5"
                    Height="30" />
            <Button Content="Скопировать View"
                    Command="{Binding CopyViewsCommand}"
					Visibility="{Binding IsSourceMode, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Margin="5"
                    Height="30" />
            <Button Content="Проверить структуру"
                    Command="{Binding CompareCommand}"
					Visibility="{Binding IsSourceMode, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Margin="5"
                    Height="30"
                    Background="#FFF4CE" />
        </UniformGrid-->
	<!--StackPanel>
	<TextBlock Text="{Binding IsSourceMode, StringFormat='Is Left Pane: {0}'}" Foreground="Red" FontWeight="Bold"/>
   </StackPanel-->	
 
    </Grid>
   </UserControl>