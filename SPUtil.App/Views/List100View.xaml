<UserControl x:Class="SPUtil.App.Views.List100View"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- Row 0: toolbar -->
            <RowDefinition Height="Auto" />  <!-- Row 1: title block -->
            <RowDefinition Height="*"    />  <!-- Row 2: TabControl -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════════
             Row 0 — Toolbar (visible in Source mode only)

             CommandParameter="{Binding ActiveTab}" passes the current ListTab
             enum value into every command so the handler knows which tab
             is active at the moment of the click.
        ════════════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="#F5F5F5"
                BorderBrush="#CCCCCC"
                BorderThickness="0,0,0,1"
                Padding="5"
                Visibility="{Binding IsSourceMode, Converter={StaticResource BooleanToVisibilityConverter}}">

            <StackPanel Orientation="Horizontal"
                        Visibility="{Binding IsSourceMode, Converter={StaticResource BooleanToVisibilityConverter}}">

                <!-- Create structure on target -->
                <Button Style="{StaticResource IconButton}"
                        Command="{Binding CreateOnTargetCommand}"
                        CommandParameter="{Binding ActiveTab}"
                        ToolTip="Create this list on the target site">
                    <TextBlock Text="&#xE710;" Style="{StaticResource IconText}" Foreground="#0078D4"/>
                </Button>

                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="5,0"/>

                <!-- Copy with data -->
                <Button Style="{StaticResource IconButton}"
                        Command="{Binding CopyWithDataCommand}"
                        CommandParameter="{Binding ActiveTab}"
                        ToolTip="Copy structure with data">
                    <TextBlock Text="&#xE8C8;" Style="{StaticResource IconText}" Foreground="#2B579A"/>
                </Button>

                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="5,0"/>

                <!-- Copy views -->
                <Button Style="{StaticResource IconButton}"
                        Command="{Binding CopyViewsCommand}"
                        CommandParameter="{Binding ActiveTab}"
                        ToolTip="Copy views only">
                    <TextBlock Text="&#xE7B3;" Style="{StaticResource IconText}" Foreground="#107C10"/>
                </Button>

                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="5,0"/>

                <!-- Compare -->
                <Button Style="{StaticResource IconButton}"
                        Command="{Binding CompareCommand}"
                        CommandParameter="{Binding ActiveTab}"
                        ToolTip="Compare structures">
                    <TextBlock Text="&#xE912;" Style="{StaticResource IconText}" Foreground="#856404"/>
                </Button>

                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="5,0"/>

                <!-- Refresh -->
                <Button Style="{StaticResource IconButton}"
                        Command="{Binding RefreshCommand}"
                        ToolTip="Refresh">
                    <TextBlock Text="&#xE72C;" Style="{StaticResource IconText}" Foreground="#555"/>
                </Button>

                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="5,0"/>

                <!-- Active-tab indicator — shows which tab is selected right now -->
                <TextBlock VerticalAlignment="Center"
                           Margin="6,0,0,0"
                           FontSize="11"
                           Foreground="#666"
                           Text="{Binding ActiveTab, StringFormat='Tab: {0}'}"/>
            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════════
             Row 1 — Title block
        ════════════════════════════════════════════════════════════════════════ -->
        <StackPanel Grid.Row="1" Margin="0,8,0,6">
            <TextBlock Text="{Binding ListTitle}"
                       FontSize="18" FontWeight="Bold" Foreground="#333333">
                <TextBlock.Effect>
                    <DropShadowEffect BlurRadius="3" Direction="315" ShadowDepth="1.5" Opacity="0.4" Color="Gray"/>
                </TextBlock.Effect>
            </TextBlock>
            <TextBlock Text="Custom List (Type 100)"
                       FontSize="16" FontWeight="SemiBold" Foreground="#0078D4"/>
            <TextBlock Text="{Binding StatusMessage}"
                       FontSize="12" Foreground="Gray" Margin="2,0,0,0"/>
        </StackPanel>

        <!-- ═══════════════════════════════════════════════════════════════════
             Row 2 — TabControl
             SelectedIndex ↔ ActiveTabIndex (int wrapper over ListTab enum).
             Switching tabs → ActiveTab updates → toolbar buttons receive the
             new value on next click via CommandParameter="{Binding ActiveTab}".
        ════════════════════════════════════════════════════════════════════════ -->
        <TabControl Grid.Row="2"
                    SelectedIndex="{Binding ActiveTabIndex, Mode=TwoWay}">

            <!-- ── Tab 0: Items ──────────────────────────────────────────── -->
            <TabItem Header="Items">
                <DataGrid ItemsSource="{Binding Items}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="False"
                          Background="White">
                    <DataGrid.Columns>
                        <DataGridCheckBoxColumn Header="Sel"
                                                Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                                Width="40"/>
                        <DataGridTextColumn Header="ID"    Binding="{Binding Id}"    IsReadOnly="True" Width="50"/>
                        <DataGridTextColumn Header="Title" Binding="{Binding Title}" IsReadOnly="True" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <!-- ── Tab 1: Fields ─────────────────────────────────────────── -->
            <TabItem Header="Fields">
                <DataGrid ItemsSource="{Binding Fields}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          Background="White">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Title"        Binding="{Binding Title}"        Width="2*"/>
                        <DataGridTextColumn Header="Internal Name"  Binding="{Binding InternalName}" Width="2*"/>
                        <DataGridTextColumn Header="Type"             Binding="{Binding TypeAsString}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <!-- ── Tab 2: Views ──────────────────────────────────────────── -->
            <TabItem Header="Views">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"   />
                        <RowDefinition Height="5"   />
                        <RowDefinition Height="180" />
                    </Grid.RowDefinitions>

                    <DataGrid Grid.Row="0"
                              ItemsSource="{Binding Views}"
                              SelectedItem="{Binding SelectedView, UpdateSourceTrigger=PropertyChanged}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              Background="White">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Title" Binding="{Binding Title}"             Width="200"/>
                            <DataGridCheckBoxColumn Header="Default" Binding="{Binding DefaultView}"   Width="60"/>
                            <DataGridTextColumn Header="URL"      Binding="{Binding ServerRelativeUrl}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch"
                                  Background="#EEE" Cursor="SizeNS"/>

                    <GroupBox Grid.Row="2" Header="CAML Query (XML)">
                        <TextBox Text="{Binding SelectedView.ViewQuery, Mode=OneWay}"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 FontFamily="Consolas"
                                 FontSize="12"
                                 Background="#F9F9F9"
                                 BorderThickness="0"
                                 Margin="2"/>
                    </GroupBox>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</UserControl>
