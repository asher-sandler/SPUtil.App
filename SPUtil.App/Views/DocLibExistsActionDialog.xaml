<Window x:Class="SPUtil.Views.DocLibExistsActionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Library Conflict"
        Height="400" Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="#F0F0F0">

    <Window.Resources>
        <Style TargetType="RadioButton">
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="DescStyle">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#777"/>
            <Setter Property="Margin" Value="20,0,0,0"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="22,20,22,10">

            <TextBlock Text="Target library already exists:"
                       FontSize="14" FontWeight="SemiBold" Foreground="#333"/>

            <TextBlock x:Name="TxtLibName"
                       Text="LibraryName"
                       FontSize="14" FontWeight="Bold" Foreground="#0066CC"
                       Margin="0,2,0,18" TextTrimming="CharacterEllipsis"/>

            <TextBlock Text="What would you like to do?"
                       Margin="0,0,0,16" Foreground="#555"/>

            <!-- Option 1: Append -->
            <RadioButton x:Name="RadioAppend" Content="Append — add only new folders and files"
                         IsChecked="True" GroupName="Action"/>
            <TextBlock Style="{StaticResource DescStyle}"
                       Text="Copies what is missing on destination. Existing content is not touched."
                       Margin="20,-4,0,12"/>

            <!-- Option 2: Overwrite -->
            <RadioButton x:Name="RadioOverwrite" Content="Overwrite — replace matching files"
                         GroupName="Action"/>
            <TextBlock Style="{StaticResource DescStyle}"
                       Text="Copies everything. Matching files are replaced. Unique content on destination stays."
                       Margin="20,-4,0,12"/>

            <!-- Option 3: Mirror -->
            <RadioButton x:Name="RadioMirror" Content="Mirror — make exact copy of source"
                         GroupName="Action"/>
            <StackPanel Orientation="Horizontal" Margin="20,-4,0,4">
                <TextBlock Text="⚠ " Foreground="#CC4400" FontSize="11"/>
                <TextBlock Style="{StaticResource DescStyle}" Margin="0"
                           Text="DELETES LIBRARY AND ALL CONTENT on destination &#x0a;and creates it from scratch!"
                           Foreground="#CC4400"/>
            </StackPanel>

        </StackPanel>

        <!-- Footer -->
        <Border Grid.Row="1" Background="#E1E1E1"
                BorderBrush="#CCCCCC" BorderThickness="0,1,0,0"
                Padding="15,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Continue" Margin="0,0,8,0" Click="BtnContinue_Click"
                        Background="#0066CC" Foreground="White" FontWeight="SemiBold"/>
                <Button Content="Cancel" Click="BtnCancel_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
