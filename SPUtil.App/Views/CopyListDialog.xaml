<Window x:Class="SPUtil.Views.CopyListDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Copy List - Options"
        Height="400" Width="500" 
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F0F0F0">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="Padding" Value="10,2"/>
            <Setter Property="Background" Value="White"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,3"/>
            <Setter Property="Foreground" Value="#444"/>
        </Style>
    </Window.Resources>

    <Grid Margin="15,10,15,15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <RowDefinition Height="Auto" /> <RowDefinition Height="Auto" /> <RowDefinition Height="*" />    <RowDefinition Height="Auto" /> </Grid.RowDefinitions>

			<GroupBox Header="Source Information" Margin="0,0,0,12" Background="White" MaxHeight="150">
				<ScrollViewer VerticalScrollBarVisibility="Auto">
					<TextBox x:Name="TxtInfo"
							 Margin="8"
							 TextWrapping="Wrap"
							 Foreground="#555"
							 Text="Loading list information..."
							 IsReadOnly="True" 
							 BorderThickness="0"
							 Background="Transparent"
							 IsReadOnlyCaretVisible="True"/>
				</ScrollViewer>
			</GroupBox>

        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="Target Site URL:"/>
            <TextBox x:Name="TxtTargetUrlName" 
                     IsReadOnly="True" 
                     Background="#E9E9E9"
                     BorderBrush="#CCC"
                     Height="26" 
                     VerticalContentAlignment="Center"
                     Padding="5,0"
                     TextWrapping="NoWrap"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,5">
            <TextBlock Text="Target List Name:" FontWeight="SemiBold" Foreground="Black"/>
            <TextBox x:Name="TxtTargetListName" 
                     Height="28" 
                     VerticalContentAlignment="Center"
                     BorderBrush="#0078D7"
                     Padding="5,0"/>
        </StackPanel>

        <Border Grid.Row="4" Padding="0,15,0,0" BorderBrush="#DDD" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Copy"
                        Width="100"
                        Margin="5,0"
                        Click="BtnCopy_Click"
                        IsDefault="True" 
                        Background="#E1F5FE" 
                        BorderBrush="#039BE5"/>
                <Button Content="Cancel"
                        Width="100"
                        Margin="5,0"
                        IsCancel="True" />
            </StackPanel>
        </Border>
    </Grid>
</Window>