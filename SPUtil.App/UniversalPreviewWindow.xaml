<Window x:Class="SPUtil.App.Views.UniversalPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Preview"
        Height="600"
        Width="900"
        WindowStartupLocation="CenterOwner"
        Background="#2D2D2D">
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBox x:Name="MainTextBox"
                 Grid.Row="0"
                 Text="{Binding PreviewText, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                 IsReadOnly="True"
                 AcceptsReturn="True"
                 FontFamily="Consolas"
                 FontSize="14"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 Background="#1E1E1E"
                 Foreground="#D4D4D4"
                 Padding="10"
                 BorderBrush="#3E3E42" />

		<Grid Grid.Row="1" Margin="0,5">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/> 
				<RowDefinition Height="Auto"/> 
			</Grid.RowDefinitions>

			<ProgressBar Grid.Row="0"
						 Height="10" 
						 Minimum="0" 
						 Maximum="100" 
						 Value="{Binding ExportProgress}" 
						 Visibility="{Binding IsExporting, Converter={StaticResource BooleanToVisibilityConverter}}"
						 VerticalAlignment="Top"/>
			
			<TextBlock Grid.Row="1"
					   Text="{Binding StatusMessage}" 
					   Foreground="Gold" 
					   FontSize="12" 
					   Margin="0,5,0,0"
					   HorizontalAlignment="Left" />
		</Grid>
		
		
        <ItemsControl Grid.Row="2" 
                      ItemsSource="{Binding DialogButtons}" 
                      HorizontalAlignment="Right"
                      Margin="0,5,0,0">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Content="{Binding Caption}" 
                            Command="{Binding ClickCommand}"
                            MinWidth="110" 
                            Height="35" 
                            Margin="5,0,0,0"
                            Background="#3E3E42"
                            Foreground="White"
                            BorderThickness="0"/>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</Window>